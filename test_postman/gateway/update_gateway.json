  "item": [
    {
      "name": "1. Update Gateway - Success - Partial Update (Sửa Model & Mạng)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"gw-uuid-thực-tế-trong-db-của-bạn\",\n  \"model\": \"ESP32-S3-WROOM-1\",\n  \"firmwareVersion\": \"v1.2.5\",\n  \"ipAddress\": \"192.168.1.88\",\n  \"macAddress\": \"24:0A:C4:C9:61:B4\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/v1/gateways/update",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "v1",
            "gateways",
            "update"
          ]
        },
        "description": "Cập nhật một phần: Chỉ sửa model, firmware, IP và MAC. Nhờ cơ chế IGNORE null, các trường như station, code, serial_number ban đầu dưới DB sẽ được bảo toàn nguyên vẹn."
      },
      "response": []
    },
